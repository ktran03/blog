---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags: string[];
}

const { title, description, date, slug, tags } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group py-6 border-b border-zinc-100 dark:border-zinc-800/60 last:border-0">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <div class="flex flex-wrap gap-1.5 mb-2">
        {tags.map(tag => (
          <a
            href={`/tags/${tag}`}
            class="tag-chip inline-block text-xs font-medium px-2 py-0.5 rounded-full bg-violet-100 dark:bg-violet-950/50 text-violet-700 dark:text-violet-300 hover:bg-violet-200 dark:hover:bg-violet-900/60"
          >
            {tag}
          </a>
        ))}
      </div>
      <a href={`/blog/${slug}`} class="block">
        <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-50 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors leading-snug mb-1">
          {title}
        </h2>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 line-clamp-2">
          {description}
        </p>
      </a>
    </div>
    <time
      datetime={date.toISOString()}
      class="flex-shrink-0 text-xs text-zinc-400 dark:text-zinc-500 font-mono mt-1"
    >
      {formattedDate}
    </time>
  </div>
</article>
