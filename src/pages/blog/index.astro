---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// All unique tags
const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();

// Active tag filter from query string
const { tag } = Astro.url.searchParams
  ? Object.fromEntries(Astro.url.searchParams)
  : {};

const filtered = tag ? posts.filter(p => p.data.tags.includes(tag)) : posts;
---

<BaseLayout title="Blog" description="All posts about AI, coding, agents, and software engineering.">
  <div class="flex items-baseline justify-between mb-6">
    <h1 class="text-2xl font-bold text-zinc-900 dark:text-zinc-50">Blog</h1>
    <span class="text-sm text-zinc-400 dark:text-zinc-500 font-mono">{posts.length} posts</span>
  </div>

  {allTags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-8">
      <a
        href="/blog"
        class:list={[
          'tag-chip text-xs font-medium px-2.5 py-1 rounded-full transition-colors',
          !tag
            ? 'bg-violet-600 text-white'
            : 'bg-zinc-100 dark:bg-zinc-800/60 text-zinc-600 dark:text-zinc-400 hover:bg-zinc-200 dark:hover:bg-zinc-700/60'
        ]}
      >
        All
      </a>
      {allTags.map(t => (
        <a
          href={`/tags/${t}`}
          class:list={[
            'tag-chip text-xs font-medium px-2.5 py-1 rounded-full transition-colors',
            tag === t
              ? 'bg-violet-600 text-white'
              : 'bg-zinc-100 dark:bg-zinc-800/60 text-zinc-600 dark:text-zinc-400 hover:bg-zinc-200 dark:hover:bg-zinc-700/60'
          ]}
        >
          {t}
        </a>
      ))}
    </div>
  )}

  {filtered.length === 0 ? (
    <p class="text-zinc-500 dark:text-zinc-400 py-8">No posts yet — check back soon.</p>
  ) : (
    <div>
      {filtered.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          slug={post.id}
          tags={post.data.tags}
        />
      ))}
    </div>
  )}
</BaseLayout>
