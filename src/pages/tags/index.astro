---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft);

const tagCounts = posts
  .flatMap(p => p.data.tags)
  .reduce<Record<string, number>>((acc, tag) => {
    acc[tag] = (acc[tag] ?? 0) + 1;
    return acc;
  }, {});

const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Tags" description="Browse posts by topic.">
  <h1 class="text-2xl font-bold text-zinc-900 dark:text-zinc-50 mb-8">Tags</h1>

  {tags.length === 0 ? (
    <p class="text-zinc-500 dark:text-zinc-400">No tags yet.</p>
  ) : (
    <div class="flex flex-wrap gap-3">
      {tags.map(([tag, count]) => (
        <a
          href={`/tags/${tag}`}
          class="tag-chip flex items-center gap-2 px-3 py-1.5 rounded-full bg-zinc-100 dark:bg-zinc-800/60 hover:bg-violet-100 dark:hover:bg-violet-950/50 text-zinc-700 dark:text-zinc-300 hover:text-violet-700 dark:hover:text-violet-300 transition-colors"
        >
          <span class="text-sm font-medium">{tag}</span>
          <span class="text-xs text-zinc-400 dark:text-zinc-500 font-mono">{count}</span>
        </a>
      ))}
    </div>
  )}
</BaseLayout>
